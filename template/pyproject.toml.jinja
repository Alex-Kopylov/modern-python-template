[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
requires-python = ">={{ python_version }}"
license = "{{ license }}"
dependencies = []

[dependency-groups]
dev = [
  # Linting & formatting
  "ruff",
  "ty",
  "flake8",
  "flake8-pydantic",
  "flake8-async",
  "vulture",
  "deptry>=0.25.1",
  "bandit",
  # Testing
  "pytest",
  "pytest-xdist",
  "pytest-cov>=7.1.0",
  # Git hooks
  "prek",
  # YAML linting
  "yamllint",
  {% if use_github_actions -%}
  # JSON schema validation
  "check-jsonschema",
  {% endif -%}
]

{% if is_package -%}
[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]
{% else -%}
# No [build-system]: uv treats this as a virtual project (deps only, the
# project itself is not built or installed). Restore hatchling + a wheel
# target once src/ gains a real package.
{% endif %}

[tool.ty.environment]
python-version = "{{ python_version }}"

[tool.coverage.run]
source = ["src"]
branch = true

[tool.coverage.report]
show_missing = true
skip_empty = true
{% if coverage_fail_under > 0 -%}
fail_under = {{ coverage_fail_under }}
{% else -%}
# Raise once the project grows real code:
# fail_under = 80
{% endif %}
