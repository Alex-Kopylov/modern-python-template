[project]
name = "{{ project_name }}"
version = "0.1.0"
description = {{ project_description | tojson }}
requires-python = ">={{ python_version_minor }}"
{% if license == 'MIT' -%}
license = "{{ license }}"
{% elif license == 'Proprietary' -%}
license = "LicenseRef-Proprietary"
{% endif -%}
dependencies = []

[dependency-groups]
dev = [
  # Linting & formatting
  "ruff",
  "ty",
  "flake8",
  "flake8-pydantic",
  "flake8-async",
  "vulture",
  "deptry>=0.25.1",
  # Testing
  "pytest",
  {% if parallel_testing %}
  "pytest-xdist",
  {% endif %}
  "pytest-cov>=7.1.0",
  # Git hooks
  "prek",
  # YAML linting
  "yamllint",
  {% if use_github_actions %}
  # JSON schema validation
  "check-jsonschema",
  {% endif %}
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.uv]
python-preference = "only-managed"

[tool.ty.environment]
python-version = "{{ python_version_minor }}"

[tool.coverage.run]
source = ["src"]
branch = true

[tool.coverage.report]
show_missing = true
skip_empty = true
{% if coverage_fail_under > 0 -%}
fail_under = {{ coverage_fail_under }}
{% else -%}
# Raise once the project grows real code:
# fail_under = 80
{% endif %}
