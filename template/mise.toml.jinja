[tools]
# Pinned like every other tool; "latest" made task runs depend on whatever
# uv happened to resolve (lint-audit needs uv >= 0.11.19 for `uv audit`).
# aqua backend: mise's core uv plugin extracts current uv tarballs incorrectly
# (binary stays under uv-<target>/ with no bin/), silently falling back to
# any system uv.
"aqua:astral-sh/uv" = "0.11.27"
{% if "jscpd" in extra_linters or "markdownlint" in extra_linters -%}
node = "22.22.0"
{% endif -%}
{% if "jscpd" in extra_linters -%}
"npm:jscpd" = "4.2.4"
{% endif -%}
{% if "markdownlint" in extra_linters -%}
"npm:markdownlint-cli2" = "0.22.1"
{% endif -%}
"aqua:01mf02/jaq" = "2.3.0"
"aqua:gitleaks/gitleaks" = "8.30.1"
"aqua:hadolint/hadolint" = "2.14.0"
"aqua:koalaman/shellcheck" = "0.11.0"
{% if use_github_actions -%}
"aqua:rhysd/actionlint" = "1.7.11"
{% endif -%}
"aqua:tamasfe/taplo" = "0.10.0"
{% if use_github_actions -%}
"aqua:zizmorcore/zizmor" = "1.25.2"
{% endif -%}
{% if "typos" in extra_linters -%}
"aqua:crate-ci/typos" = "1.20.7"
{% endif %}

# Python tools managed via uv (installed in venv)
# Accessible via `uv run <tool>` after `uv sync`
[tasks.flake8]
description = "Run flake8 async checks"
run = "uv run flake8"

[tasks.install]
description = "Install the project and its dependencies"
run = "uv sync --all-extras"

[tasks.lint]
description = "Run the full lint suite"
run = [
  { tasks = ["lint-full"] },
]

[tasks.lint-fast]
description = "Run fast, edit-safe linters"
run = [
  { tasks = [
    "lint-python-fast",
    "lint-dockerfile",
    {% if "markdownlint" in extra_linters %}
    "lint-md",
    {% endif %}
    "lint-yml",
    "lint-json",
    "lint-toml",
    {% if use_github_actions %}
    "lint-github-actions",
    {% endif %}
    {% if "typos" in extra_linters %}
    "lint-typos",
    {% endif %}
  ] },
]

[tasks.lint-full]
description = "Run fast linters plus whole-project gate checks"
run = [
  { tasks = [
    "lint-fast",
    "lint-python-deep",
    "lint-deps",
    {% if "jscpd" in extra_linters %}
    "lint-duplicates",
    {% endif %}
    "lint-secrets",
    "lint-audit",
    {% if use_github_actions %}
    "lint-gha-security",
    {% endif %}
  ] },
]

[tasks.lint-python-fast]
description = "Run fast Python checks"
run = [
  "uv run ruff check src tests",
  "uv run ruff format --check src tests",
  "uv run flake8 src",
]

[tasks.lint-python-deep]
description = "Run whole-project Python analysis"
run = [
  "uv run ty check src",
  "uv run vulture --config .vulture.toml",
]

[tasks.lint-dockerfile]
description = "Lint Dockerfiles with Hadolint"
run = "mise exec -- hadolint Dockerfile"

{% if "markdownlint" in extra_linters -%}
[tasks.lint-md]
description = "Lint Markdown files"
run = "mise exec -- markdownlint-cli2"

{% endif -%}
[tasks.lint-yml]
description = "Lint YAML files"
run = "uv run yamllint -c .yamllint ."

[tasks.lint-json]
description = "Validate JSON syntax with jaq"
{% if "jscpd" in extra_linters -%}
run = "mise exec -- jaq empty .jscpd.json"
{% else -%}
run = "find . -name '*.json' -not -path './.venv/*' -not -path './node_modules/*' -exec mise exec -- jaq empty {} +"
{% endif %}

[tasks.lint-toml]
description = "Lint TOML files with Taplo"
run = "mise exec -- taplo lint"

{% if use_github_actions -%}
[tasks.lint-github-actions]
description = "Lint GitHub Actions workflow files"
run = [
  "mise exec -- actionlint",
  "uv run check-jsonschema --builtin-schema github-workflows .github/workflows/ci.yml",
]

{% endif -%}
{% if "jscpd" in extra_linters -%}
[tasks.lint-duplicates]
description = "Detect duplicated code"
run = "mise exec -- jscpd --config .jscpd.json --threshold 5"

{% endif -%}
[tasks.lint-deps]
description = "Check Python dependency declarations"
run = "uv run deptry ."

[tasks.lint-secrets]
description = "Scan git history for leaked secrets"
run = "mise exec -- gitleaks git --redact --no-banner"

{% if use_github_actions -%}
[tasks.lint-gha-security]
description = "Scan GitHub Actions workflows for security issues"
run = "mise exec -- zizmor .github/workflows/ci.yml"

{% endif -%}
[tasks.lint-audit]
description = "Scan Python dependencies for known CVEs"
run = "uv audit"

{% if "typos" in extra_linters -%}
[tasks.lint-typos]
description = "Scan for spelling mistakes"
run = "mise exec -- typos"

{% endif -%}
[tasks.test]
description = "Run the pytest suite"
run = "uv run pytest tests/"

[tasks.test-cov]
description = "Run the pytest suite with a coverage report"
run = "uv run pytest tests/ --cov --cov-report=term-missing"

[tasks.format]
description = "Format and autofix Python and TOML files"
run = [
  "uv run ruff format src tests",
  "uv run ruff check --fix src tests",
  "mise exec -- taplo fmt",
]

[tasks.install-hooks]
description = "Install prek-managed pre-commit and pre-push hooks"
run = "uv run prek install --hook-type pre-commit --hook-type pre-push"

[tasks.clean]
description = "Remove local build and test cache directories"
run = [
  "find . -type d -name __pycache__ -exec rm -rf {} +",
  "find . -type d -name .pytest_cache -exec rm -rf {} +",
  "rm -rf dist build *.egg-info",
]
