{
  // markdownlint-cli2 configuration
  // Uses .markdownlint.jsonc for rules, this file for CLI options
  // See: https://github.com/DavidAnson/markdownlint-cli2

  // Suppress verbose discovery output
  "noBanner": true,
  "noProgress": true,

  // Paths to lint
  "globs": [
    "*.md",
{% if use_github_actions %}
    ".github/**/*.md",
{% endif %}
    "docs/**/*.md"
  ],

  // Exclusions (AI instruction files and internal documentation)
  "ignores": [
    "CLAUDE.md",
    "AGENTS.md",
    "GEMINI.md",
    "docs/specs/**",
    "docs/internal/**"
  ]
}
